  "repository": {
    "type": "git",
    "url": "https://github.com/wasdjkl/wasdjkl"
  },
  "bugs": {
    "url": "https://github.com/wasdjkl/wasdjkl/issues"
  },
  "husky": {
    "hooks": {
      "pre-commit": "yarn format"
