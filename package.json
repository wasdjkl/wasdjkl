    "gatsby-remark-smartypants": "^2.9.0",
    "gatsby-source-filesystem": "^2.10.0",
    "gatsby-transformer-remark": "^2.15.0",
    "gatsby-transformer-sharp": "^2.11.0",
    "normalize.css": "^8.0.1",
    "prism-themes": "^1.5.0",
    "prismjs": "^1.21.0",
